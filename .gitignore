# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

.env

# compiled output
dist
tmp
out-tsc

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

