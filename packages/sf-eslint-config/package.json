{
  "name": "@fabio.caffarello/sf-eslint-config",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@scout-fabric/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "!**/*.tsbuildinfo"
  ],
  "publishConfig": {
    "access": "public"
  },
  "nx": {
    "name": "sf-eslint-config",
    "tags": [
      "scope:public",
      "type:config"
    ]
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "dependencies": {
    "@nx/eslint-plugin": "22.7.5",
    "eslint-config-prettier": "^10.1.8",
    "tslib": "^2.3.0"
  }
}
